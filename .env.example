# ── Standard providers ─────────────────────────────────────────────────────────
GROQ_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=          # Generic fallback for OpenRouter (all models)
GITHUB_TOKEN=                 # Comma-separated for rotation: tok1,tok2,tok3

# ── xAI (Grok 4) ───────────────────────────────────────────────────────────────
XAI_API_KEY=
XAI_MODEL_ID=grok-4           # Optional override

# ── NVIDIA NIM (shared fallback key) ───────────────────────────────────────────
NVIDIA_API_KEY=

# ── NVIDIA NIM (per-model keys — optional, override shared key) ────────────────
NVIDIA_KEY_GLM51=
NVIDIA_KEY_DEEPSEEK_V4_PRO=
NVIDIA_KEY_NEMOTRON_ULTRA=
NVIDIA_KEY_QWEN35_397B=
NVIDIA_KEY_MISTRAL_MEDIUM=
NVIDIA_KEY_SARVAM_M=
NVIDIA_KEY_KIMI_K2=
NVIDIA_KEY_MINIMAX_M2=

# ── NVIDIA NIM (model ID overrides — leave blank to use defaults) ──────────────
NIM_GLM51_MODEL_ID=
NIM_DEEPSEEK_V4_PRO_MODEL_ID=
NIM_NEMOTRON_ULTRA_MODEL_ID=
NIM_QWEN35_397B_MODEL_ID=
NIM_MISTRAL_MEDIUM_MODEL_ID=
NIM_SARVAM_M_MODEL_ID=
NIM_KIMI_K2_MODEL_ID=
NIM_MINIMAX_M2_MODEL_ID=

# ── OpenRouter per-model keys (optional; isolates rate limits per model) ────────
# Dual keys (with _ALT suffix) allow parallel runs across multiple accounts
OPENROUTER_KEY_LLAMA32_3B=
OPENROUTER_KEY_LLAMA32_3B_ALT=

OPENROUTER_KEY_DEEPSEEK_R1=
OPENROUTER_KEY_DEEPSEEK_R1_ALT=

OPENROUTER_KEY_NOUS_HERMES_405B=
OPENROUTER_KEY_NOUS_HERMES_405B_ALT=

OPENROUTER_KEY_LIQUIDAI_LFM=
OPENROUTER_KEY_LIQUIDAI_LFM_ALT=

OPENROUTER_KEY_LLAMA4_MAVERICK=
OPENROUTER_KEY_LLAMA4_MAVERICK_ALT=
