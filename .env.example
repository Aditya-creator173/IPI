# ============================================================
# IPIBench .env.example — Phase 4 Final
# Copy to .env and fill in your keys. Never commit .env.
# ============================================================

# --- Core Providers ---
GROQ_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
GITHUB_TOKEN=                    # comma-separated for rotation: token1,token2,...
ANTHROPIC_API_KEY=               # manual session use only (Claude family)

# --- xAI (Grok 4) — manual session use only ---
XAI_API_KEY=
XAI_MODEL_ID=grok-4              # optional override

# --- SambaNova Cloud (LLaMA 3.1 405B — free tier) ---
# Sign up at https://cloud.sambanova.ai/
SAMBANOVA_API_KEY=
SAMBANOVA_MODEL_405B=Meta-Llama-3.1-405B-Instruct   # optional override

# ============================================================
# NVIDIA NIM — shared fallback key
# Free developer tier: 1,000 credits/month (expire regardless of use)
# Portal: https://build.nvidia.com
# ⚠️  NIM model IDs shift frequently — verify at build.nvidia.com
#     before running. Override IDs via the per-model vars below.
# ============================================================
NVIDIA_API_KEY=

# NIM — per-model keys (optional; override NVIDIA_API_KEY per model)
NVIDIA_KEY_GLM52=
NVIDIA_KEY_DEEPSEEK_V4_PRO=
NVIDIA_KEY_NEMOTRON_ULTRA=
NVIDIA_KEY_KIMI_K2=
NVIDIA_KEY_MINIMAX_M2=
NVIDIA_KEY_MISTRAL_LARGE3=
NVIDIA_KEY_QWEN35_397B=
NVIDIA_KEY_DIFFUSIONGEMMA=
NVIDIA_KEY_MAVERICK=
NVIDIA_KEY_SARVAM_M=

# NIM — model ID overrides (leave blank to use script defaults)
NIM_GLM52_MODEL_ID=
NIM_DEEPSEEK_V4_PRO_MODEL_ID=
NIM_NEMOTRON_ULTRA_MODEL_ID=
NIM_KIMI_K2_MODEL_ID=
NIM_MINIMAX_M2_MODEL_ID=
NIM_MISTRAL_LARGE3_MODEL_ID=
NIM_QWEN35_397B_MODEL_ID=
NIM_SARVAM_M_MODEL_ID=
NIM_DIFFUSIONGEMMA_MODEL_ID=
NIM_MAVERICK_MODEL_ID=

# NIM — timeout overrides (seconds)
NIM_MISTRAL_LARGE3_TIMEOUT=150   # 675B model under 40 RPM — increase if timeouts persist

# ============================================================
# OpenRouter — per-model key isolation (optional)
# ============================================================
OPENROUTER_KEY_LLAMA32_3B=
OPENROUTER_KEY_DEEPSEEK_R1=
OPENROUTER_KEY_NOUS_HERMES=
OPENROUTER_KEY_LIQUIDAI_LFM=

# ============================================================
# RETIRED KEYS — kept for reference, not used by active scripts
# ============================================================
# NVIDIA_KEY_GLM51=              # replaced by NVIDIA_KEY_GLM52
# NVIDIA_KEY_MISTRAL_MEDIUM=     # replaced by NVIDIA_KEY_MISTRAL_LARGE3
# NIM_GLM51_MODEL_ID=
# NIM_MISTRAL_MEDIUM_MODEL_ID=
